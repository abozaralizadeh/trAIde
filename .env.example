AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.2
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# Optional: Azure APIM fronting Azure OpenAI (use subscription key)
AZURE_APIM_OPENAI_SUBSCRIPTION_KEY=
AZURE_APIM_OPENAI_API_VERSION=2024-08-01-preview
AZURE_APIM_OPENAI_ENDPOINT=https://your-apim-name.azure-api.net/
AZURE_APIM_OPENAI_DEPLOYMENT=your-deployment-name

KUCOIN_API_KEY=your-kucoin-api-key
KUCOIN_API_SECRET=your-kucoin-secret
KUCOIN_API_PASSPHRASE=your-kucoin-passphrase
KUCOIN_BASE_URL=https://api.kucoin.com
# KuCoin Futures base URL (default futures endpoint)
KUCOIN_FUTURES_BASE_URL=https://api-futures.kucoin.com

# Optional KuCoin Futures (uses the same KUCOIN_API_* credentials)
KUCOIN_FUTURES_ENABLED=true

# Comma-separated list of symbols to monitor/trade (e.g., BTC-USDT,ETH-USDT)
COINS=BTC-USDT,ETH-USDT,SOL-USDT,XRP-USDT,DOGE-USDT
# Allow the agent to curate the coin list dynamically (true/false)
FLEXIBLE_COINS_ENABLED=true
# After this many consecutive agent runs with no trade (stuck/declining), force a handoff to
# the Research Agent to overhaul the coin list and surface fresh opportunities. 0 disables.
RESEARCH_HANDOFF_AFTER_NO_TRADE_RUNS=3
# Min minutes between forced Research handoffs (rate-limits the costly web-research sweep). 0=off.
RESEARCH_HANDOFF_COOLDOWN_MIN=30

# --- Risk guardrails (added after the RE-USDT concentration blowup) ---
# Block LONGs on non-major alts while BTC's daily regime is bearish (alts are high-beta to BTC).
ALT_LONG_BLOCK_WHEN_BTC_BEARISH=true
# Symbols exempt from the alt-long gate (they have their own daily gate).
ALT_MAJORS=BTC,ETH
# Cap a single position's notional at this fraction of total equity, regardless of leverage. 0=off.
MAX_POSITION_EQUITY_PCT=0.5
# Block entries on futures contracts younger than this many days (freshly-listed = thin/volatile). 0=off.
MIN_FUTURES_LISTING_AGE_DAYS=7
# Minimum reward:risk for a futures entry: reject when the TP distance < this × the SL distance.
# Fixes the big-loss/small-win asymmetry (stops were being set wider than targets). 0=off.
MIN_FUTURES_RR=1.5
# Market screener liquidity floor: scan_futures_market only surfaces perps with at least this much
# 24h USDT turnover (keeps discovery to liquid coins; rejects thin micro-caps). Lower = wider net.
SCREENER_MIN_TURNOVER_USD_24H=5000000

# --- Adaptive edge controller (src/edge.py) — self-tuning risk from rolling realized results ---
# When the last N closes are net-losing: RR floor rises, repeatedly-losing symbols are benched,
# and entries shrink during loss streaks. Relaxes back automatically when expectancy turns positive
# — no manual re-tuning needed as regimes change.
ADAPTIVE_EDGE_ENABLED=true
EDGE_LOOKBACK_TRADES=30        # rolling window of realized closes for the stats
EDGE_MIN_TRADES=8              # minimum closes before adaptive actions kick in
EDGE_RR_STEP=0.5               # added to MIN_FUTURES_RR while rolling expectancy < 0
EDGE_RR_CAP=2.5                # ceiling for the adaptive RR floor
EDGE_RR_STALE_HOURS=18         # if no close in this long, the RR raise decays back to base — a losing
                               # streak old enough to have frozen trading shouldn't keep the bar raised
                               # (that lockout prevents the very wins that would lower it)
EDGE_SYMBOL_RR_MIN_TRADES=2    # min closes ON A SYMBOL before its OWN RR floor is raised. The RR floor is
                               # per-symbol: a symbol you keep losing on must clear base+step, but fresh /
                               # winning names stay at base — so one bad coin no longer starves diversification
EDGE_BENCH_LOOKBACK=5          # per-symbol recent closes examined for the bench
EDGE_BENCH_MIN_LOSSES=3        # losses within that window (with negative net) that bench a symbol
EDGE_BENCH_COOLDOWN_HOURS=12   # base bench rest; scaled by loss count so a persistent loser sits out longer
EDGE_BENCH_COOLDOWN_MAX_MULT=4 # cap on that scaling (e.g. 12h × 4 = up to 48h for a chronically-losing symbol)
EDGE_STREAK_THRESHOLD=2        # consecutive realized losses that trigger the size throttle
EDGE_STREAK_SIZE_FACTOR=0.5    # entry-size multiplier while on a losing streak
# Futures margin mode: cross | isolated | auto. The cross-leverage call is only issued in cross mode.
KUCOIN_FUTURES_MARGIN_MODE=cross
# Fraction of agent runs traced to LangSmith (head sampling; avoids the monthly unique-trace cap).
LANGSMITH_SAMPLE_RATE=0.1

# --- Conviction sizing (added after SOL drawdown: full-size low-conviction shorts) ---
# Scale position size by how far confidence clears the floor: low-conviction entries size down,
# ramping to full size as conviction rises. Targets the agent's own "mixed/low-conviction" reads.
CONVICTION_SIZING_ENABLED=true
CONVICTION_FULL_CONFIDENCE=0.85   # confidence at/above which full size is used
CONVICTION_MIN_SIZE_FACTOR=0.5    # size multiplier at the confidence floor (linear ramp up to 1.0)

# --- Deadlock break (added after the daily-vs-1h both-blocked stall recurred) ---
# In a clean (non-exhausted) daily trend, allow the daily-aligned entry (short in a bearish daily,
# long in a bullish daily) past the 1h gate when a 1h counter-bounce is stalling (15m no longer
# confirms it) and confidence clears a raised bar — so the bot isn't stranded flat in both directions.
DEADLOCK_BREAK_ENABLED=true
DEADLOCK_MIN_CONFIDENCE=0.72       # raised confidence bar to take the trend-continuation entry

# Safety controls
PAPER_TRADING=true
MAX_POSITION_USD=500
RISK_PER_TRADE_PCT=0.02   # 1-2% is the best-practice survival rule; high-frequency bots lean to the low end
MIN_CONFIDENCE=0.65
SENTIMENT_FILTER_ENABLED=false
SENTIMENT_MIN_SCORE=0.55
MAX_LEVERAGE=3
MAX_TRADES_PER_SYMBOL_PER_DAY=6   # cap per-symbol churn (more trades = more fee drag + loss streaks)
MIN_NET_PROFIT_USD=0.5
MIN_PROFIT_ROI_PCT=0.008
ESTIMATED_SLIPPAGE_PCT=0.001
# Enable regime-aware range trading (mean-reversion in sideways markets)
RANGE_TRADING_ENABLED=true

# Advanced trading features
PARTIAL_TP_ENABLED=true
KELLY_SIZING_ENABLED=true
KELLY_MIN_TRADES=30
PREFER_LIMIT_ORDERS=true
LIMIT_ORDER_TIMEOUT_SEC=20
POST_LOSS_COOLDOWN_MINUTES=30
MAX_ENTRY_LEVERAGE=3              # keep <=5x (conservative); higher only for tight-stop scalps
MIN_TRADE_INTERVAL_MINUTES=10    # min spacing between entries on a symbol (anti-overtrading)
MAX_24H_VOLATILITY_PCT=25
MAX_ATR_PCT_FOR_ENTRY=6

# Circuit breakers (auto-restrict trading when risk thresholds exceeded)
CB_MAX_DAILY_DRAWDOWN_PCT=5.0    # daily loss limit ~2-3x per-trade risk; stop digging the hole
CB_MAX_CONSECUTIVE_LOSSES=3
CB_MAX_PORTFOLIO_HEAT_PCT=6.0    # total open risk if all stops hit at once ("6% rule")
CB_COOLDOWN_MINUTES=120

# Profit protection (code-driven, enforced outside the LLM — see src/protection.py)
# P1: ratchet the stop to breakeven once a trade reaches +N×risk, and close it if it
#     gives back too much of its peak run. P2: don't re-enter the same direction at a
#     worse price right after taking profit (the chase that caused the ETH round-trip).
PROFIT_LOCK_ENABLED=true
PROFIT_LOCK_DRY_RUN=false            # true = log intended actions without placing orders (observe first)
PROFIT_LOCK_BREAKEVEN_TRIGGER_R=1.0  # move stop to breakeven at this multiple of initial risk (>=1R is the consensus floor)
PROFIT_LOCK_BREAKEVEN_FEE_PCT=0.0015 # round-trip cost buffer (KuCoin futures taker 0.06%x2 + slippage) so breakeven nets >=0
PROFIT_LOCK_GIVEBACK_PCT=0.35        # close after retracing this fraction of the peak run; 0.35 retains ~65% of MFE (0 disables)
PROFIT_LOCK_MIN_FE_PCT=0.005         # min run (fraction of entry) before give-back can act — filters noise
PROFIT_LOCK_GIVEBACK_ARM_R=1.0       # ALSO require the run to reach this multiple of the trade's own risk (stop
                                     # distance) before give-back can act — stops booking fee-scale scratch wins
                                     # while losses ride to the full stop. 0 = pct-arming only (legacy)
NO_CHASE_ENABLED=true
POST_WIN_COOLDOWN_MINUTES=45         # window after a winning close during which re-entry at a worse price is blocked
NO_CHASE_BUFFER_PCT=0.001            # tolerance band around the prior exit price

# Regime-aware entries (code-enforced — see src/regime.py)
# B: in a hostile (bearish / RSI-exhausted) daily, raise the confidence bar and shrink size so the
#    bot trades less and more selectively instead of churning bounce-scalps in a downtrend.
# D: permit trend-aligned shorts (shorting a confirmed downtrend) past the anti-FOMO gate, instead
#    of only ever longing oversold bounces — but only with 1h+15m confirmation and higher conviction.
REGIME_THROTTLE_ENABLED=true
REGIME_CAUTION_MIN_CONFIDENCE=0.75   # elevated confidence floor when the daily is bearish/exhausted
REGIME_CAUTION_SIZE_FACTOR=0.6       # position-size multiplier in a hostile regime
TREND_ALIGNED_SHORTS_ENABLED=true
TREND_SHORT_MIN_CONFIDENCE=0.78      # higher confidence bar specifically for a counter-bounce short
TREND_SHORT_REQUIRE_15M=true         # require 15m (not just 1h) bearish confirmation for the short
# Reversal long: allow a LONG past a bearish daily gate when 1h+15m have both turned bullish and
# confidence is high. The daily trend lags at bottoms, so without this the bot cannot catch a
# reversal (it sat out an +11% ETH bounce in the Jul 2-5 2026 chop). Majors only (alt longs stay
# blocked by the correlation gate). The reward:risk floor still applies to whatever passes.
REVERSAL_LONGS_ENABLED=true
REVERSAL_LONG_MIN_CONFIDENCE=0.80    # high bar — counter-daily longs are only for confirmed turns
REVERSAL_LONG_REQUIRE_15M=true       # require 15m (not just 1h) bullish confirmation

# Langsmith tracing (optional, no LangChain required)
LANGSMITH_ENABLED=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=trAIde
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_TRACING=true

# Looping/scheduling
POLL_INTERVAL_SEC=60
PRICE_CHANGE_TRIGGER_PCT=0.5
MAX_IDLE_POLLS=10
AGENT_MAX_TURNS=100

# Agent memory
MEMORY_FILE=.agent_memory.json
RETENTION_DAYS=14

# Telegram notifications (create a bot via @BotFather, get chat_id via getUpdates)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SILENT=false

# Supervisor Agent (interactive Telegram bot — responds to your messages)
SUPERVISOR_ENABLED=false
LOG_FILE=traide.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=3

# Public spectator dashboard publishing (Azure Blob + Table)
# Persists a SANITIZED, public-safe view of agent decisions/performance to Azure so a
# read-only website (SandBox repo) can visualize it. Never publishes balances, equity,
# position sizes, account IDs, or API keys. Reuses the `connection_string` below.
DASHBOARD_PUBLISH_ENABLED=false
# Azure Storage connection string (account-level). Same var name the SandBox consumer reads.
connection_string=
# Azure Table name (durable, queryable history) and Blob container (rolled-up JSON snapshots).
TRAIDE_TABLE_NAME=traidedashboard
TRAIDE_BLOB_NAME=traide-dashboard
# Minimum seconds between publishes (the trading loop calls the publisher every poll; it self-throttles).
DASHBOARD_PUBLISH_INTERVAL_SEC=300
# Money disclosure: normalized (% returns + indexed curve only, no $) | absolute ($ realized PnL, no balances) | both
DASHBOARD_DISCLOSURE=normalized
# How many recent decisions to include in the live feed.
DASHBOARD_FEED_LIMIT=30
# Starting value of the normalized equity index (curve begins here).
DASHBOARD_INDEX_BASE=100

# Tracing (Azure Monitor via OTLP/HTTP)
ENABLE_TRACING=false
# Enable verbose console span export (dev only)
ENABLE_CONSOLE_TRACING=false
# If you want to export spans to OpenAI traces endpoint (per tutorial)
OPENAI_TRACE_API_KEY=
# Example for Azure Monitor data collection endpoint (DCE):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://<your-dce>.<region>.ingest.monitor.azure.com
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <dce-token-or-apim-key>
